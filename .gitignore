# Quarto build artifacts and local execution caches
# /_site/
/.quarto/
/site_libs/
/_freeze/site_libs/
**/*_files/
**/*_cache/
!_site/**/*_files/
!_site/**/*_files/**

# Exclude all assessment files from all modules
*/assessments/

# Office documents (generally not needed for website build)
*.docx
*.doc
*.pptx
*.ppt
*.xlsx
*.xls

# But keep Excel data files that are referenced in Quarto docs
!data/*.xlsx
!data/*.xls
!data/**/*.xlsx
!data/**/*.xls

# LaTeX auxiliary files
*.aux
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.nav
*.snm
*.vrb

# Temporary files
*.tmp
*.temp
*.bak
*.orig
*~
.#*
#*#

# Office temporary files
~$*

# Backup files
*.backup

# Python cache (if any)
__pycache__/
*.pyc

# Node modules (if any)
node_modules/

# OS generated files
._.DS_Store
.Spotlight-V100
.Trashes
ehthumbs.db

# Compressed files (unless specifically needed for data)
*.zip
*.tar.gz
*.rar
!data/*.zip
!data/**/*.zip

# Allow source SVG figures to be tracked
!vignettes/figures/**/*.svg

**/*.quarto_ipynb

# Re-ignore macOS metadata under _site
_site/**/.DS_Store

/.luarc.json
/.claude/worktrees/
